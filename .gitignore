# ── Dependencies ────────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/

# ── Build outputs ────────────────────────────────────────────────────────────
dist/
build/
frontend/dist/
coverage/
*.tsbuildinfo

# ── Environment / secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Runtime: sandbox (FilesAgent writes here) ────────────────────────────────
sandbox/*
!sandbox/.gitkeep

# ── Runtime: memory persistence ─────────────────────────────────────────────
data/*
!data/.gitkeep

# ── Runtime: audit logs ─────────────────────────────────────────────────────
logs/*
!logs/.gitkeep

# ── Runtime: generated docs / reports ───────────────────────────────────────
docs/*
!docs/.gitkeep
!docs/roadmap-profesional.md

# ── OS / editor ─────────────────────────────────────────────────────────────
.DS_Store
.vscode/
.idea/
Thumbs.db

# ── npm logs ─────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ── Misc ─────────────────────────────────────────────────────────────────────
.cache/
.tmp/
temp/
