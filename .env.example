# ─── Azure OpenAI — Text model (Responses API) ───────────────────────────────
# URL base del recurso (sin /responses ni ?api-version)
AZURE_OPENAI_ENDPOINT=https://corp-coe-data-westus.openai.azure.com/openai
AZURE_OPENAI_API_KEY=your-text-model-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini
AZURE_API_VERSION=2024-04-01-preview

# ─── Azure AI Inference — Embedding model ────────────────────────────────────
# URL base del deployment (sin /embeddings ni ?api-version)
AZURE_EMBEDDING_ENDPOINT=https://corp-coe-data-westus.openai.azure.com/openai/deployments/text-embedding-3-small-metis
AZURE_EMBEDDING_API_KEY=your-embedding-key-here
AZURE_EMBEDDING_API_VERSION=2023-05-15

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3010
